%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 0}
  m_Name: New Tutorial Sequence
  m_EditorClassIdentifier: Assembly-CSharp::Tutorial_Catalog_Scriptable/TutorialSequence
  tutorialSteps:
  - speaker: 'Player:'
    tutorialText: "Ugh\u2026 where am I?\n\nThis cave\u2026 something about it feels
      wrong.\n\nBetter get moving. Try walking with A and D."
    trigger: 2
  - speaker: 'Player:'
    tutorialText: "The ground here is uneven\u2026 I\u2019ll need to jump to get
      around.\n\nPress Space to jump."
    trigger: 3
  - speaker: 'Player:'
    tutorialText: "Wait\u2026 what are those?\n\nLittle spirits? They look trapped
      inside those cages\u2026"
    trigger: 3
  - speaker: 'Water:'
    tutorialText: "\"Traveler! Over here!\n\nWe are elemental sprites \u2014 Earth,
      Fire, Water, and Air.\""
    trigger: 3
  - speaker: 'Fire:'
    tutorialText: "\"An evil wizard captured us. He plans to sacrifice us to steal
      our elemental magic.\n\nIf that happens\u2026 the balance of the elements could
      be destroyed!\""
    trigger: 3
  - speaker: 'Earth:'
    tutorialText: '"You can still help us!


      Pull the lever and we will escape.
      but you can only save one of us."'
    trigger: 5
  - speaker: 'Air:'
    tutorialText: '"The lever is on that moving platform.  Jump onto it and pull
      the lever."  Right Click while standing near it.'
    trigger: 6
  - speaker: 
    tutorialText: "\"There is a puzzle ahead that blocks your path.\"  \"I can release
      my elemental power to help you.\"  \"Throw me at something using Left Click.\" 
      \"If I strike the right object\u2026 my power will awaken.\""
    trigger: 6
