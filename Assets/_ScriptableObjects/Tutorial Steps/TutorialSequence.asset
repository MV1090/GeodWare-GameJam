%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 743a379d72c331e48a401fbb8bcf5f83, type: 3}
  m_Name: TutorialSequence
  m_EditorClassIdentifier: Assembly-CSharp::TutorialSequence
  tutorialSteps:
  - speaker: 'Player:'
    tutorialText: '"Ugh... where am I?\n This cave, something about it feels wrong.\nBetter
      get moving." \n\nUse Arrow Keys to move.'
    trigger: 1
    speakerSprite: {fileID: 0}
  - speaker: 'Player:'
    tutorialText: '"The ground here is uneven. \nI''ll need to jump to get around."
      \n\nUse Space to jump.'
    trigger: 2
    speakerSprite: {fileID: 0}
  - speaker: 'Player:'
    tutorialText: '"Wait... what are those?\nLittle spirits? They look trapped inside
      those cages."'
    trigger: 4
    speakerSprite: {fileID: 0}
  - speaker: 'Water:'
    tutorialText: '"Traveler! Over here!\n We are elemental spirits. \nEarth, Fire,
      Water, and Air."'
    trigger: 4
    speakerSprite: {fileID: 0}
  - speaker: 'Fire:'
    tutorialText: '"An evil wizard captured us. He plans to sacrifice us to steal
      our elemental magic.\nIf that happens the balance of the elements could be
      destroyed!"'
    trigger: 4
    speakerSprite: {fileID: 0}
  - speaker: Earth
    tutorialText: '"You can still help us! \nPull the lever and we will escape. \nBut
      you can only save one of us."'
    trigger: 4
    speakerSprite: {fileID: 0}
  - speaker: 'Air:'
    tutorialText: '"The lever is on that moving platform.  Jump onto it and pull
      the lever."  \n\nUse E while standing near it.'
    trigger: 4
    speakerSprite: {fileID: 0}
  - speaker: 'spirit:'
    tutorialText: '"There is a puzzle ahead that blocks your path. I can release
      my elemental power to help you. \nThrow me at something."  \n"If I strike the
      right object my power will awaken." \n\nUse Q to throw.'
    trigger: 6
    speakerSprite: {fileID: 0}
  - speaker: 'spirit:'
    tutorialText: '"Don''t worry if you make a mistake, this place has powers to
      rewind time." \n\nUse R to rest level. '
    trigger: 6
    speakerSprite: {fileID: 0}
